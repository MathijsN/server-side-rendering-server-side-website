{% render 'partials/head.liquid', title: 'Homepage' %}

<main>
{% render 'partials/top-navigation.liquid' %}

  <ul class="grid-view">
    {% for snappmap in snappmaps %}
      {% for snap in snappmap.snaps %}
        {% if snap.picture != null %}
          <li>
            <a href="/snapmap/{{ snap.uuid }}">
                <img src="https://fdnd-agency.directus.app/assets/{{ snap.picture }}" loading="lazy">
            </a>
          </li>
        {% endif %}
      {% endfor %}
    {% endfor %}
  </ul>

  {% render 'partials/bottom-navigation.liquid' %}
</main>
